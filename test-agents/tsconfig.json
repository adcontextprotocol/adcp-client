{
  "compilerOptions": {
    "target": "ES2022",
    "module": "Node16",
    "moduleResolution": "Node16",
    "strict": true,
    "skipLibCheck": true,
    "outDir": "dist",
    "paths": {
      "@adcp/sdk": ["../dist/lib/index.d.ts"],
      "@adcp/sdk/server": ["../dist/lib/server/index.d.ts"],
      "@adcp/sdk/server/legacy/v5": ["../dist/lib/server/legacy/v5/index.d.ts"],
      "@adcp/sdk/signing": ["../dist/lib/signing/index.d.ts"]
